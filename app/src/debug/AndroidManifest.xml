<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- Debug-only receipts hatch: adb shell am broadcast -a dev.phosphor.mobil3.SELFTEST
             -n dev.phosphor.mobil3/.SelfTestReceiver. Release builds don't carry it. -->
        <receiver
            android:name=".SelfTestReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.phosphor.mobil3.SELFTEST" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
